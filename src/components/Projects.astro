---
import {PROJECTS} from 'src/data/proyects'

---

<div class="grid grid-cols-1 gap-6 md:grid-cols-2">
  {
    PROJECTS.map(({ title, description, tags }) => (
    <article class="rounded-xl border border-black/10 bg-white/80 p-5 shadow-sm dark:border-white/10 dark:bg-zinc-900/70">
      <h3 class="text-2xl font-bold text-gray-800 dark:text-gray-100">{title}</h3>
      <div class="mt-3 text-gray-700 dark:text-gray-300">{description}</div>
      <ul class="mt-4 flex flex-wrap gap-2">
          {tags.map((tag) => (
            <li>
              <span
                class={`flex gap-x-2 rounded-full text-xs ${tag.class} py-1 px-2 `}
              >
                <tag.icon class="size-4" />
                {tag.name}
              </span>
            </li>
          ))}
      </ul>
    </article>
    ))
  }
</div>