---
import {DIPLOMAS} from '@/data/diplomas'
import Badge from './Badge.astro';
---

<div class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2">
      {
        DIPLOMAS.map(({ title, institution, date, description, tags }) => (
          <article class="rounded-xl border border-black/10 bg-white/80 p-5 shadow-sm dark:border-white/10 dark:bg-zinc-900/70">
              <h3 class="text-lg font-semibold text-gray-800 dark:text-gray-100">{title}</h3>
              <p class="mt-1 text-sm text-gray-700 dark:text-gray-300">{institution} | {date}</p>
              <p class="mt-2 text-sm text-gray-700 dark:text-gray-300">{description}</p>
              <div class="mt-3">
                <ul class="flex flex-wrap gap-2">
                  {tags.map((tag) => (
                    <Badge>{tag.name}</Badge>
                  ))}
                </ul>
              </div>
          </article>
        ))
      }
</div>
